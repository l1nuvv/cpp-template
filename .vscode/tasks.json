{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure debug",
            "type": "process",
            "command": "cmake",
            "args": [
                "--preset",
                "msvc-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: build debug",
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "msvc-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake: configure debug"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake: run debug",
            "type": "process",
            "command": "${workspaceFolder}/build/msvc-debug/Debug/cpp-study-template.exe",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake: build debug"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "CMake: build release",
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "msvc-release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake: clean debug",
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "msvc-debug",
                "--target",
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
